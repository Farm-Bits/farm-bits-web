<!DOCTYPE html>
<html>
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Invitation to <%= @company.name %></title>
    <style>
      body {
        font-family: system-ui, -apple-system, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
        line-height: 1.6;
        color: #4b5563;
        margin: 0;
        padding: 0;
        background: linear-gradient(135deg, #f0fdf4 0%, #ecfdf5 100%);
      }

      .container {
        max-width: 600px;
        margin: 0 auto;
        background: white;
        border-radius: 24px;
        overflow: hidden;
        box-shadow: 0 20px 60px rgba(0, 0, 0, 0.1);
        margin-top: 40px;
        margin-bottom: 40px;
      }

      .header {
        background: linear-gradient(135deg, #059669 0%, #047857 100%);
        color: white;
        padding: 48px 32px;
        text-align: center;
        position: relative;
        overflow: hidden;
      }

      .header::before {
        content: '';
        position: absolute;
        top: -50%;
        left: -50%;
        width: 200%;
        height: 200%;
        background: radial-gradient(circle at 50% 50%, rgba(255,255,255,0.1) 0%, transparent 70%);
        animation: pulse 3s ease-in-out infinite;
      }

      @keyframes pulse {
        0%, 100% { opacity: 0.5; }
        50% { opacity: 0.8; }
      }

      .header h1 {
        margin: 0;
        font-size: 32px;
        font-weight: 700;
        position: relative;
        z-index: 1;
      }

      .header-icon {
        width: 64px;
        height: 64px;
        background: rgba(255, 255, 255, 0.2);
        border-radius: 16px;
        margin: 0 auto 16px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 28px;
        position: relative;
        z-index: 1;
      }

      .content {
        padding: 40px 32px;
        background: white;
      }

      .content h2 {
        color: #1f2937;
        font-size: 28px;
        font-weight: 700;
        margin: 0 0 24px 0;
        text-align: center;
      }

      .invitation-card {
        background: linear-gradient(135deg, #f0fdf4 0%, #ecfdf5 100%);
        border: 1px solid #d1fae5;
        border-radius: 16px;
        padding: 24px;
        margin: 24px 0;
        text-align: center;
      }

      .inviter-info {
        font-size: 18px;
        color: #1f2937;
        margin-bottom: 16px;
      }

      .company-name {
        color: #059669;
        font-weight: 700;
      }

      .inviter-name {
        color: #059669;
        font-weight: 600;
      }

      .role-badge {
        display: inline-block;
        background: linear-gradient(135deg, #2563eb 0%, #1d4ed8 100%);
        color: white;
        padding: 8px 16px;
        border-radius: 12px;
        font-weight: 600;
        font-size: 14px;
        letter-spacing: 0.5px;
        text-transform: uppercase;
        box-shadow: 0 4px 12px rgba(37, 99, 235, 0.3);
      }

      .role-description {
        background: #eff6ff;
        border: 1px solid #bfdbfe;
        border-radius: 12px;
        padding: 20px;
        margin: 20px 0;
        border-left: 4px solid #2563eb;
      }

      .role-description h3 {
        color: #1d4ed8;
        margin: 0 0 8px 0;
        font-size: 16px;
        font-weight: 600;
      }

      .button-container {
        text-align: center;
        margin: 32px 0;
      }

      .button {
        display: inline-block;
        padding: 16px 32px;
        background: linear-gradient(135deg, #059669 0%, #047857 100%);
        color: white;
        text-decoration: none;
        border-radius: 16px;
        font-weight: 600;
        font-size: 16px;
        box-shadow: 0 8px 24px rgba(5, 150, 105, 0.3);
        transition: all 0.3s ease;
        transform: translateY(0);
      }

      .button:hover {
        transform: translateY(-2px);
        box-shadow: 0 12px 32px rgba(5, 150, 105, 0.4);
      }

      .link-fallback {
        background: #f9fafb;
        border: 1px solid #e5e7eb;
        border-radius: 12px;
        padding: 16px;
        margin: 16px 0;
        word-break: break-all;
      }

      .link-fallback-label {
        color: #6b7280;
        font-size: 14px;
        margin-bottom: 8px;
      }

      .link-fallback-url {
        color: #059669;
        font-weight: 500;
        font-size: 14px;
      }

      .divider {
        height: 1px;
        background: linear-gradient(90deg, transparent 0%, #e5e7eb 50%, transparent 100%);
        margin: 32px 0;
      }

      .expiry-notice {
        background: #fef3c7;
        border: 1px solid #f59e0b;
        border-radius: 12px;
        padding: 16px;
        margin: 24px 0;
        border-left: 4px solid #f59e0b;
      }

      .expiry-notice h3 {
        color: #92400e;
        margin: 0 0 8px 0;
        font-size: 16px;
        font-weight: 600;
      }

      .expiry-notice p {
        color: #92400e;
        margin: 0;
      }

      .footer {
        padding: 32px;
        text-align: center;
        color: #6b7280;
        font-size: 14px;
        background: #f9fafb;
        border-top: 1px solid #f3f4f6;
      }

      .footer p {
        margin: 8px 0;
      }

      @media (max-width: 600px) {
        .container {
          margin: 20px;
          border-radius: 16px;
        }

        .header {
          padding: 32px 24px;
        }

        .content {
          padding: 24px 20px;
        }

        .header h1 {
          font-size: 24px;
        }

        .content h2 {
          font-size: 22px;
        }
      }
    </style>
  </head>
  <body>
    <div class="container">
      <div class="header">
        <div class="header-icon">🎉</div>
        <h1>You're Invited!</h1>
      </div>

      <div class="content">
        <h2>Join <%= @company.name %></h2>

        <div class="invitation-card">
          <div class="inviter-info">
            <span class="inviter-name"><%= @inviter.name %></span> has invited you to join <span class="company-name"><%= @company.name %></span>
          </div>
          <div style="margin: 16px 0;">
            with the role of <span class="role-badge"><%= @role.titleize %></span>
          </div>
        </div>

        <% case @role %>
        <% when 'admin' %>
          <div class="role-description">
            <h3>👑 Administrator Access</h3>
            <p>As an <strong>Admin</strong>, you'll have full access to all sites and can manage company settings, users, and permissions.</p>
          </div>
        <% when 'manager' %>
          <div class="role-description">
            <h3>🛠️ Manager Access</h3>
            <p>As a <strong>Manager</strong>, you'll have edit access to assigned sites and can create new sites and manage team members.</p>
          </div>
        <% when 'viewer' %>
          <div class="role-description">
            <h3>👁️ Viewer Access</h3>
            <p>As a <strong>Viewer</strong>, you'll have read-only access to assigned sites and can view reports and analytics.</p>
          </div>
        <% end %>

        <p style="text-align: center; font-size: 18px; color: #1f2937; margin: 24px 0;">
          Ready to get started? Accept your invitation below:
        </p>

        <div class="button-container">
          <a href="<%= @accept_url %>" class="button">Accept Invitation</a>
        </div>

        <div class="link-fallback">
          <div class="link-fallback-label">Or copy and paste this link into your browser:</div>
          <div class="link-fallback-url"><%= @accept_url %></div>
        </div>

        <div class="divider"></div>

        <div class="expiry-notice">
          <h3>⏰ Time Sensitive</h3>
          <p>This invitation will expire on <strong><%= @expires_at.strftime("%B %d, %Y at %I:%M %p") %></strong>.</p>
        </div>

        <p style="color: #6b7280; text-align: center;">
          If you don't want to accept this invitation, you can simply ignore this email.
        </p>
      </div>

      <div class="footer">
        <p>This invitation was sent by <strong><%= @inviter.name %></strong> from <strong><%= @company.name %></strong>.</p>
        <p>If you have any questions, please contact your inviter directly.</p>
      </div>
    </div>
  </body>
</html>
